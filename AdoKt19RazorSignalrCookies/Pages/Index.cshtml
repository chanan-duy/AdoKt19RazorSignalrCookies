@page
@model IndexModel
@{
	ViewData["Title"] = "home";
}

<div class="home-page">
	<h1 class="mb-3">chat demo</h1>
	<p class="text-secondary mb-4">
		cookie authentication, sqlite users, and a protected signalr chat.
	</p>

	<div class="row g-3 mb-4">
		<div class="col-md-4">
			<div class="card h-100">
				<div class="card-body">
					<h2 class="h5">step 1</h2>
					<p class="mb-0">register a user account.</p>
				</div>
			</div>
		</div>

		<div class="col-md-4">
			<div class="card h-100">
				<div class="card-body">
					<h2 class="h5">step 2</h2>
					<p class="mb-0">login with your username and password.</p>
				</div>
			</div>
		</div>

		<div class="col-md-4">
			<div class="card h-100">
				<div class="card-body">
					<h2 class="h5">step 3</h2>
					<p class="mb-0">open the chat page and send messages.</p>
				</div>
			</div>
		</div>
	</div>

	@if (User.Identity?.IsAuthenticated == true)
	{
		<div class="alert alert-light border d-flex flex-wrap justify-content-between align-items-center gap-3">
			<div>
				<div class="fw-semibold">signed in as @User.Identity.Name</div>
				<div class="text-secondary small">you can open the protected chat now.</div>
			</div>

			<a class="btn btn-primary" asp-page="/Chat">open chat</a>
		</div>
	}
	else
	{
		<div class="d-flex flex-wrap gap-2">
			<a class="btn btn-primary" asp-page="/Account/Register">register</a>
			<a class="btn btn-outline-secondary" asp-page="/Account/Login">login</a>
		</div>
	}
</div>
